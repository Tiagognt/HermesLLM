  <div style="display: none" class="modal app-modal" id="publishFormPrompt">
    <div class="modal-dialog">
      <div class="modal-content">
        <div class="modal-header">
          <button aria-label="Close" data-dismiss="modal" class="close" type="button"><span aria-hidden="true">×</span></button>
          <h4 class="modal-title">Publish for others to fill &amp; sign</h4>
        </div>
        <div class="modal-body">
          <div class="block">
            We don't offer document storage. Your document will be saved in your Google Drive <strong>and shared publicly with anyone that has access to the link.</strong>
            <img data-src="/images/icons/sejda.png" loading="lazy" class="help-block-icon"><img data-src="/images/icons/gdrive.png" loading="lazy" class="help-block-icon">
          </div>
          <div class="block">
            We'll generate a link that opens the document with Sejda, allowing others to fill &amp; sign the form and send it back to you by email.
            Share the link on your website or in your emails.
            Link does not expire.
          </div>
          <div class="block">
            We'll save your changes to continue.
          </div>
        </div>
        <div class="modal-footer">
          <button style="margin-right: 15px;" class="btn btn-medium btn-ok wide" type="button">Continue</button>
        </div>
      </div>
    </div>
  </div>
  
