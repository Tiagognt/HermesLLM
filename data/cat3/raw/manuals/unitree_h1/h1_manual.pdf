                <button class="btn btn-default clone-btn" title="Duplicate field">
                  <i class="far fa-clone"></i>
                </button>
              </div>
              <div role="group" class="btn-group">
                <button class="btn btn-default delete-opts" title="Delete">
                  <i class="far fa-trash"></i>
                </button>
              </div>
            </div>
          </div>

